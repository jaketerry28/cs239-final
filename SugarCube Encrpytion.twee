:: Interactive Encrypter {"position":"1275,25","size":"100,100"}
<h1>Interactive Encrypter</h1>

<h2>Here you can try out encrypting and decrypting your own messages!</h2>

Enter text: <<textbox "$plaintext" "">>

<<button "Encrypt">>
	<<run
		let shift = 3;
		let text = State.variables.plaintext || "";
		let result = "";

		for (let i = 0; i < text.length; i++) {
			let ch = text[i];

			if (ch >= 'a' && ch <= 'z') {
				result += String.fromCharCode((ch.charCodeAt(0) - 97 + shift) % 26 + 97);
			}
			else if (ch >= 'A' && ch <= 'Z') {
				result += String.fromCharCode((ch.charCodeAt(0) - 65 + shift) % 26 + 65);
			}
			else {
				result += ch;
			}
		}

		State.variables.ciphertext = result;
	>>
	<<replace "#output">><span class="obscure-in">Result: <<= $ciphertext>></span><</replace>>
<</button>>

<<button "Decrypt">>
	<<run
		let shift = 3;
		let text = State.variables.plaintext || "";
		let result = "";

		for (let i = 0; i < text.length; i++) {
			let ch = text[i];

			if (ch >= 'a' && ch <= 'z') {
				result += String.fromCharCode((ch.charCodeAt(0) - 97 - shift + 26) % 26 + 97);
			}
			else if (ch >= 'A' && ch <= 'Z') {
				result += String.fromCharCode((ch.charCodeAt(0) - 65 - shift + 26) % 26 + 65);
			}
			else {
				result += ch;
			}
		}

		State.variables.ciphertext = result;
	>>
	<<replace "#output">><span class="obscure-in">Result: <<= $ciphertext>></span><</replace>>
<</button>>

<div id="output"></div>

<h3>Crack the code for a surprise</h3>

<p>Decipher: <em>wkdwv rqh frro fdw kxqwhu</em></p>

Enter the decrypted phrase: <<textbox "$guess" "">>
<span id="password-output"></span>

<<button "Unlock Secret">>
	<<run
		let answer = "thats one cool cat hunter";
		let guess = (State.variables.guess || "").trim().toLowerCase();

		if (guess === answer) {
			let audio = new Audio("https://raw.githubusercontent.com/jaketerry28/cs239-final/main/dragon-studio-wow-423653.mp3");
			audio.play().then(() => {
				Engine.play("Hunter Secret");
			}).catch(() => {
				Engine.play("Hunter Secret");
			});
		} else {
			$("#password-output").text("Incorrect password. Try again.");
		}
	>>
<</button>>


